# --- Deployment ---
PRIVATE_KEY=0x_your_deployer_private_key
RPC_URL=https://sepolia.infura.io/v3/your_key

# Issuer allowed to write certificates + link ENS (LendSignal backend / CRE signer).
# Optional: defaults to the deployer address if unset.
ISSUER=0x_your_issuer_address

# ERC20 loan asset for the vault. Optional: if unset, a MockERC20 (mUSDC) is deployed.
ASSET=

# ENS registry for the onchain ENS gate. Optional: if set, the gate is wired on at deploy.
# Mainnet / Sepolia / Holesky: 0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
ENS_REGISTRY=

# --- Offchain signal sources (used by the backend that fills ScoreInputs) ---
# 1) Chainlink Confidential AI Attester (the "CRI" signal)
CHAINLINK_CONFIDENTIAL_AI_BASE_URL=https://confidential-ai-dev-preview.cldev.cloud
CHAINLINK_CONFIDENTIAL_AI_API_KEY=
CHAINLINK_CONFIDENTIAL_AI_MODEL=gemma4

# 2) Offchain CRS credit-risk bureau
CRS_API_BASE_URL=
CRS_API_CLIENT_ID=
CRS_API_CLIENT_SECRET=
CRS_USE_MOCK=true
